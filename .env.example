# Telegram Bot API credentials.
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit it.
#
# How to get these:
#   TELEGRAM_BOT_TOKEN: message @BotFather on Telegram → /newbot → follow prompts
#   TELEGRAM_CHAT_ID:   message your bot once, then visit
#                       https://api.telegram.org/bot<TOKEN>/getUpdates
#                       and look for "chat":{"id": ... }

TELEGRAM_BOT_TOKEN=replace_with_token_from_botfather
TELEGRAM_CHAT_ID=replace_with_your_numeric_chat_id
